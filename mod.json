{
	"geode": "5.3.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "xblazegmd.omg",
	"name": "OMG!",
	"version": "v1.1.0",
	"developer": "XblazeGMD",
	"description": "npesta be like",
	"dependencies": {
		"geode.node-ids": ">=v1.20.0"
	},
	"tags": ["joke", "offline", "interface"],
	"links": {"source": "https://github.com/xblazegmd/OMG"},
	"resources": {
		"files": [
			"resources/*.mp3"
		]
	},
	"settings": {
		"basic-title": {
			"type": "title",
			"name": "Basic Settings"
		},
		"quick-enable": {
			"type": "bool",
			"name": "Enabled",
			"description": "Enable/Disable the mod without needing to restart the game",
			"default": true
		},
		"volume": {
			"type": "int",
			"enable-if": "quick-enable",
			"enable-if-description": "Please enable the mod :)",
			"name": "Volume",
			"description": "The volume for the reaction\n\n<cr>Some reactions are louder than others, so be careful!</c>",
			"default": 50,
			"min": 0,
			"max": 100,
			"control": {
				"slider": true
			}
		},
		"reaction": {
			"type": "string",
			"name": "Reaction",
			"default": "Random",
			"one-of": [
				"Random",
				"Kenos (Npesta)",
				"Bloodbath (Riot)",
				"Bloodlust (Knobbelboy)",
				"Nhelv (Kingsammelot)",
				"Thinking Space II (Zoink)",
				"Slaugherhouse (SpaceUK's \"completion\")",
				"Flamewall (Cuatrocientos)",
				"Silent Clubstep (Doggie)",
				"Unnerfed Sary Never Clear (Glow)",
				"Rupture (Cold)",
				"Unnerfed Zodiac (nebnoob)"
			]
		},
		"swearuk": {
			"type": "bool",
			"name": "SwearUK",
			"enable-if": "quick-enable",
			"enable-if-description": "Please enable the mod :)",
			"description": "Show the uncensored version of the SpaceUK reaction\n\n<co>(Contains profanity, may not be appropriate for all ages)</c>",
			"default": false
		},
		"no-blank-title": {
			"type": "title",
			"name": "Enable/Disable reactions"
		},
		"no-normal": {
			"type": "bool",
			"name": "No Reaction On Normal Mode",
			"enable-if": "quick-enable",
			"enable-if-description": "Please enable the mod :)",
			"description": "Do not play any reaction when playing on normal mode",
			"default": false
		},
		"no-practice": {
			"type": "bool",
			"name": "No Reaction On Practice",
			"enable-if": "quick-enable",
			"enable-if-description": "Please enable the mod :)",
			"description": "Do not play any reaction when playing on practice mode",
			"default": true
		},
		"no-startpos": {
			"type": "bool",
			"enable-if": "quick-enable",
			"enable-if-description": "Please enable the mod :)",
			"name": "No Reaction On Startpos",
			"description": "Do not play any reaction when playing on a start position",
			"default": true
		}
	}
}
